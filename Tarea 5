# Problema 2: Promoción en menú de restaurante

# Matriz del menú: [Nombre del Producto, Categoría, Precio Base]
menu = [
    ["Hamburguesa clásica", "Comida rápida", 18000],
    ["Pizza personal", "Comida rápida", 22000],
    ["Ensalada César", "Saludable", 16000],
    ["Jugo natural", "Bebidas", 8000],
    ["Limonada de coco", "Bebidas", 12000],
    ["Salmón a la plancha", "Plato fuerte", 35000],
    ["Pasta carbonara", "Plato fuerte", 28000]
]

# Datos de la promoción
categoria_objetivo = "Plato fuerte"
umbral_precio = 25000
descuento = 0.15


# Función para calcular el precio final
def calcular_precio_final(categoria, precio_base):
    if categoria == categoria_objetivo and precio_base > umbral_precio:
        precio_final = precio_base - (precio_base * descuento)
    else:
        precio_final = precio_base

    return precio_final


# Mostrar resultados
print("MENÚ DEL RESTAURANTE CON PROMOCIÓN")
print("-" * 60)

for producto in menu:
    nombre = producto[0]
    categoria = producto[1]
    precio_base = producto[2]

    precio_final = calcular_precio_final(categoria, precio_base)

    print(f"Producto: {nombre}")
    print(f"Categoría: {categoria}")
    print(f"Precio base: ${precio_base:,.0f}")
    print(f"Precio final: ${precio_final:,.0f}")
    print("-" * 60)
